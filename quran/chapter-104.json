{
  "schemaVersion": 2,
  "bookCode": "QUR",
  "bookSlug": "quran",
  "n": 104,
  "paragraphs": [
    {
      "n": 1,
      "refId": "QUR-104:1",
      "text": "بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ وَيْلٌ لِّكُلِّ هُمَزَةٍ لُّمَزَةٍ"
    },
    {
      "n": 2,
      "refId": "QUR-104:2",
      "text": "الَّذِي جَمَعَ مَالًا وَعَدَّدَهُ"
    },
    {
      "n": 3,
      "refId": "QUR-104:3",
      "text": "يَحْسَبُ أَنَّ مَالَهُ أَخْلَدَهُ"
    },
    {
      "n": 4,
      "refId": "QUR-104:4",
      "text": "كَلَّا لَيُنبَذَنَّ فِي الْحُطَمَةِ"
    },
    {
      "n": 5,
      "refId": "QUR-104:5",
      "text": "وَمَا أَدْرَاكَ مَا الْحُطَمَةُ"
    },
    {
      "n": 6,
      "refId": "QUR-104:6",
      "text": "نَارُ اللَّهِ الْمُوقَدَةُ"
    },
    {
      "n": 7,
      "refId": "QUR-104:7",
      "text": "الَّتِي تَطَّلِعُ عَلَى الْأَفْئِدَةِ"
    },
    {
      "n": 8,
      "refId": "QUR-104:8",
      "text": "إِنَّهَا عَلَيْهِم مُّؤْصَدَةٌ"
    },
    {
      "n": 9,
      "refId": "QUR-104:9",
      "text": "فِي عَمَدٍ مُّمَدَّدَةٍ"
    }
  ]
}
