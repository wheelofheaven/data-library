  "n": 94,
  "paragraphs": [
    {
      "n": 1,
      "refId": "QUR-94:1",
      "text": "بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ أَلَمْ نَشْرَحْ لَكَ صَدْرَكَ"
    },
    {
      "n": 2,
      "refId": "QUR-94:2",
      "text": "وَوَضَعْنَا عَنكَ وِزْرَكَ"
    },
    {
      "n": 3,
      "refId": "QUR-94:3",
      "text": "الَّذِي أَنقَضَ ظَهْرَكَ"
    },
    {
      "n": 4,
      "refId": "QUR-94:4",
      "text": "وَرَفَعْنَا لَكَ ذِكْرَكَ"
    },
    {
      "n": 5,
      "refId": "QUR-94:5",
      "text": "فَإِنَّ مَعَ الْعُسْرِ يُسْرًا"
    },
    {
      "n": 6,
      "refId": "QUR-94:6",
      "text": "إِنَّ مَعَ الْعُسْرِ يُسْرًا"
    },
    {
      "n": 7,
      "refId": "QUR-94:7",
      "text": "فَإِذَا فَرَغْتَ فَانصَبْ"
    },
    {
      "n": 8,
      "refId": "QUR-94:8",
      "text": "وَإِلَىٰ رَبِّكَ فَارْغَب"
    }
  ]
}
