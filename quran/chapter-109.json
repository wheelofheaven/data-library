  "paragraphs": [
    {
      "n": 1,
      "refId": "QUR-109:1",
      "text": "بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ قُلْ يَا أَيُّهَا الْكَافِرُونَ"
    },
    {
      "n": 2,
      "refId": "QUR-109:2",
      "text": "لَا أَعْبُدُ مَا تَعْبُدُونَ"
    },
    {
      "n": 3,
      "refId": "QUR-109:3",
      "text": "وَلَا أَنتُمْ عَابِدُونَ مَا أَعْبُدُ"
    },
    {
      "n": 4,
      "refId": "QUR-109:4",
      "text": "وَلَا أَنَا عَابِدٌ مَّا عَبَدتُّمْ"
    },
    {
      "n": 5,
      "refId": "QUR-109:5",
      "text": "وَلَا أَنتُمْ عَابِدُونَ مَا أَعْبُدُ"
    },
    {
      "n": 6,
      "refId": "QUR-109:6",
      "text": "لَكُمْ دِينُكُمْ وَلِيَ دِينِ"
    }
  ]
}
