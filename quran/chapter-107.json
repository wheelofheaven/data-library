{
  "schemaVersion": 2,
  "bookCode": "QUR",
  "bookSlug": "quran",
  "n": 107,
  "paragraphs": [
    {
      "n": 1,
      "refId": "QUR-107:1",
      "text": "بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ أَرَأَيْتَ الَّذِي يُكَذِّبُ بِالدِّينِ"
    },
    {
      "n": 2,
      "refId": "QUR-107:2",
      "text": "فَذَٰلِكَ الَّذِي يَدُعُّ الْيَتِيمَ"
    },
    {
      "n": 3,
      "refId": "QUR-107:3",
      "text": "وَلَا يَحُضُّ عَلَىٰ طَعَامِ الْمِسْكِينِ"
    },
    {
      "n": 4,
      "refId": "QUR-107:4",
      "text": "فَوَيْلٌ لِّلْمُصَلِّينَ"
    },
    {
      "n": 5,
      "refId": "QUR-107:5",
      "text": "الَّذِينَ هُمْ عَن صَلَاتِهِمْ سَاهُونَ"
    },
    {
      "n": 6,
      "refId": "QUR-107:6",
      "text": "الَّذِينَ هُمْ يُرَاءُونَ"
    },
    {
      "n": 7,
      "refId": "QUR-107:7",
      "text": "وَيَمْنَعُونَ الْمَاعُونَ"
    }
  ]
}
