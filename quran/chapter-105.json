{
  "schemaVersion": 2,
  "bookCode": "QUR",
  "bookSlug": "quran",
  "n": 105,
  "paragraphs": [
    {
      "n": 1,
      "refId": "QUR-105:1",
      "text": "بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ أَلَمْ تَرَ كَيْفَ فَعَلَ رَبُّكَ بِأَصْحَابِ الْفِيلِ"
    },
    {
      "n": 2,
      "refId": "QUR-105:2",
      "text": "أَلَمْ يَجْعَلْ كَيْدَهُمْ فِي تَضْلِيلٍ"
    },
    {
      "n": 3,
      "refId": "QUR-105:3",
      "text": "وَأَرْسَلَ عَلَيْهِمْ طَيْرًا أَبَابِيلَ"
    },
    {
      "n": 4,
      "refId": "QUR-105:4",
      "text": "تَرْمِيهِم بِحِجَارَةٍ مِّن سِجِّيلٍ"
    },
    {
      "n": 5,
      "refId": "QUR-105:5",
      "text": "فَجَعَلَهُمْ كَعَصْفٍ مَّأْكُولٍ"
    }
  ]
}
