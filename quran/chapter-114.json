{
  "schemaVersion": 2,
  "bookCode": "QUR",
  "bookSlug": "quran",
  "n": 114,
  "paragraphs": [
    {
      "n": 1,
      "refId": "QUR-114:1",
      "text": "بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ قُلْ أَعُوذُ بِرَبِّ النَّاسِ"
    },
    {
      "n": 2,
      "refId": "QUR-114:2",
      "text": "مَلِكِ النَّاسِ"
    },
    {
      "n": 3,
      "refId": "QUR-114:3",
      "text": "إِلَٰهِ النَّاسِ"
    },
    {
      "n": 4,
      "refId": "QUR-114:4",
      "text": "مِن شَرِّ الْوَسْوَاسِ الْخَنَّاسِ"
    },
    {
      "n": 5,
      "refId": "QUR-114:5",
      "text": "الَّذِي يُوَسْوِسُ فِي صُدُورِ النَّاسِ"
    },
    {
      "n": 6,
      "refId": "QUR-114:6",
      "text": "مِنَ الْجِنَّةِ وَالنَّاسِ"
    }
  ]
}
