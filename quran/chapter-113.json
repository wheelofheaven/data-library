  "n": 113,
  "paragraphs": [
    {
      "n": 1,
      "refId": "QUR-113:1",
      "text": "بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ قُلْ أَعُوذُ بِرَبِّ الْفَلَقِ"
    },
    {
      "n": 2,
      "refId": "QUR-113:2",
      "text": "مِن شَرِّ مَا خَلَقَ"
    },
    {
      "n": 3,
      "refId": "QUR-113:3",
      "text": "وَمِن شَرِّ غَاسِقٍ إِذَا وَقَبَ"
    },
    {
      "n": 4,
      "refId": "QUR-113:4",
      "text": "وَمِن شَرِّ النَّفَّاثَاتِ فِي الْعُقَدِ"
    },
    {
      "n": 5,
      "refId": "QUR-113:5",
      "text": "وَمِن شَرِّ حَاسِدٍ إِذَا حَسَدَ"
    }
  ]
}
