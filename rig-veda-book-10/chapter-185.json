  "paragraphs": [
    {
      "n": 1,
      "refId": "RV10-185:1",
      "text": "translated by"
    },
    {
      "n": 2,
      "refId": "RV10-185:2",
      "text": "1. GREAT, unassailable must he the heavenly favour of' Three Gods,"
    },
    {
      "n": 3,
      "refId": "RV10-185:3",
      "text": "Varuna, Mitra, Aryaman."
    },
    {
      "n": 4,
      "refId": "RV10-185:4",
      "text": "2. O'er these, neither at home nor yet abroad or pathways that are Strange,"
    },
    {
      "n": 5,
      "refId": "RV10-185:5",
      "text": "The evil-minded foe hath power"
    },
    {
      "n": 6,
      "refId": "RV10-185:6",
      "text": "3. Nor over him, the man on whom the Sons of Aditi bestow Eternal light that he may live."
    }
  ]
}
